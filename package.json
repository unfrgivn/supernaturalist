{
  "name": "supernaturalist",
  "version": "0.1.0",
  "description": "Analyze supernatural language in your coding agent chats",
  "type": "module",
  "bin": {
    "supernaturalist": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node dist/cli.js",
    "build": "node build.js",
    "dev": "node build.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "format": "oxfmt --check src/",
    "test": "node tests/detector.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.1",
    "esbuild": "^0.25.0",
    "oxlint": "^0.16.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  }
}
